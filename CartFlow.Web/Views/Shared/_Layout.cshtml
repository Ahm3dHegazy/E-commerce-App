@inject CartFlow.Data.Data.AppDbContext DbContext
@using System.Security.Claims
@using CartFlow.Web.Extensions
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CartFlow</title>
    <script type="importmap"></script>
    <script>
            (function() {
                var theme = localStorage.getItem('theme');
                if (!theme) theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
                document.documentElement.setAttribute('data-theme', theme);
            })();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CartFlow.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
    <header class="site-header">
        <nav class="navbar navbar-expand-lg navbar-light py-2">
            <div class="container-lg">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">CartFlow</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto align-items-lg-center gap-lg-1">
                        @await Component.InvokeAsync("CategoryMenu")
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Products" asp-action="Index">Products</a></li>
                        
                 <li class="nav-item">
                        <a class="nav-link d-flex align-items-center gap-1"
                                    asp-area=""
                                    asp-controller="Products"
                                    asp-action="Wishlist">
                        <i class="bi bi-heart"></i>

                                    Wishlist
                        </a>
                 </li>

                        <li class="nav-item">
                            <a class="nav-link position-relative" asp-area="" asp-controller="Cart" asp-action="Index">
                                Cart
                                @{
                                    var userIdString = Context.User.FindFirstValue(ClaimTypes.NameIdentifier);
                                    int itemsCount = 0;

                                    if (!string.IsNullOrEmpty(userIdString) && int.TryParse(userIdString, out int loggedInUserId))
                                    {
                                        itemsCount = DbContext.CartItems
                                            .Where(ci => ci.Cart.UserId == loggedInUserId)
                                            .Sum(ci => ci.Quantity);
                                    }
                                    else
                                    {
                                        // Try to read guest cart from session
                                        try
                                        {
                                            var sessionCart = Context.Session.GetObject<List<CartFlow.Web.Models.CartItemViewModel>>("Cart");
                                            if (sessionCart != null)
                                            {
                                                itemsCount = sessionCart.Sum(ci => ci.Quantity);
                                            }
                                        }
                                        catch
                                        {
                                            itemsCount = 0;
                                        }
                                    }
                                }
                                <span id="cartCountBadge" class="badge bg-danger rounded-pill"
                                      style="position: absolute; top: -2px; right: -8px; font-size: 0.65rem; padding: 0.25em 0.45em; display: @(itemsCount > 0 ? "inline-block" : "none");">
                                    @itemsCount
                                </span>
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-1">
                        <button class="theme-toggle" id="themeToggle" title="Toggle theme" type="button">☀</button>
                        <form class="d-flex nav-search" role="search" asp-controller="Products" asp-action="Index" method="get">
                            <div class="input-group input-group-sm">
                                <button class="btn btn-outline-primary" type="submit"><i class="bi bi-search"></i></button>
                                <input class="form-control" type="search" name="searchTerm" placeholder="Search products…" aria-label="Search" />
                            </div>
                        </form>
                    </div>

                    <ul class="navbar-nav align-items-lg-center gap-lg-1">
                        @if (Context.User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown d-flex align-items-center gap-1">
                                <a class="nav-link" asp-action="Profile" asp-controller="Account">
                                    <i class="bi bi-person-circle fs-5"></i>
                                    @(ViewData["UserName"] ?? Context.User.Identity?.Name ?? "User")
                                </a>
                                <button class="btn btn-link nav-link p-0" data-bs-toggle="dropdown" aria-expanded="false" title="Menu">
                                    <i class="bi bi-list fs-4"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-action="Profile" asp-controller="Account">My Profile</a></li>
                                    <li><a class="dropdown-item" asp-action="MyOrders" asp-controller="Orders">My Orders</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-action="Logout" asp-controller="Account">Log out</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link nav-link--muted" asp-area="" asp-controller="Account" asp-action="SignIn">Sign in</a></li>
                            <li class="nav-item"><a class="btn btn-primary btn-sm nav-cta" asp-area="" asp-controller="Account" asp-action="SignUp">Sign up</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container-lg py-4" role="main">
        @RenderBody()
    </main>

    <footer class="site-footer border-top">
        <div class="container-lg py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>&copy; 2026 - CartFlow</span>
            <div class="d-flex gap-3">
                <a asp-controller="Home" asp-action="About">About Us</a>
                <a asp-controller="Home" asp-action="Contact">Contact Us</a>
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </div>
    </footer>

    <div class="cart-modal-overlay" id="cartModalOverlay">
        <div class="cart-modal" role="dialog" aria-modal="true" aria-labelledby="cartModalMessage">
            <button type="button" class="cart-modal-close" id="cartModalClose" aria-label="Close">&times;</button>
            <p class="cart-modal-message" id="cartModalMessage">Product was successfully added to your cart.</p>
            <div class="cart-modal-actions">
                <button type="button" class="btn-continue-shopping" id="cartModalContinue">Continue shopping</button>
                <a class="btn-view-cart" asp-controller="Cart" asp-action="Index">View Cart</a>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            var overlay = document.getElementById('cartModalOverlay');
            if (!overlay) return;

            function hide() { overlay.classList.remove('show'); }

            window.showAddedToCartModal = function () { overlay.classList.add('show'); };

            document.getElementById('cartModalClose').addEventListener('click', hide);
            document.getElementById('cartModalContinue').addEventListener('click', hide);
            overlay.addEventListener('click', function (e) {
                if (e.target === overlay) hide();
            });
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') hide();
            });
        })();

        // Intercept every "Add to Cart" form and submit it via fetch so the
        // confirmation modal can be shown without a full page reload.
        document.addEventListener('submit', async function (e) {
            var form = e.target;
            if (!form.classList || !form.classList.contains('add-to-cart-form')) return;

            e.preventDefault();
            var button = form.querySelector('button[type="submit"]');
            var originalDisabled = button ? button.disabled : false;
            if (button) button.disabled = true;

            try {
                const res = await fetch(form.action, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: new FormData(form)
                });

                if (!res.ok) throw new Error('Network response was not ok');

                const data = await res.json();

                var badge = document.getElementById('cartCountBadge');
                if (badge && typeof data.cartCount === 'number') {
                    badge.textContent = data.cartCount;
                    badge.style.display = data.cartCount > 0 ? 'inline-block' : 'none';
                }

                if (typeof window.showAddedToCartModal === 'function') {
                    window.showAddedToCartModal();
                }
            } catch (err) {
                console.error('Add to cart error', err);
                // Fall back to a normal form submission if the request failed.
                form.submit();
            } finally {
                if (button) button.disabled = originalDisabled;
            }
        });
    </script>
    <script>
            (function() {
                var btn = document.getElementById('themeToggle');
                if (!btn) return;
                var theme = document.documentElement.getAttribute('data-theme');
                btn.textContent = theme === 'dark' ? '☀' : '☾';
                btn.addEventListener('click', function() {
                    var html = document.documentElement;
                    var next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
                    html.setAttribute('data-theme', next);
                    localStorage.setItem('theme', next);
                    this.textContent = next === 'dark' ? '☀' : '☾';
                });
            })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>