@model CartViewModel

@{
    ViewData["Title"] = "Cart";
}

<div class="page-section">
    @if (Model != null && Model.Items != null && Model.Items.Any())
    {
        <section class="section-card">
            <div class="section-header section-header--row">
                <div>
                    <p class="section-label">Cart</p>
                    <h1>Your shopping cart</h1>
                    <p class="section-text">Review and adjust the items before checkout.</p>
                </div>
                <div class="summary-chip summary-chip--price">
                    <strong>@Model.Items.Sum(i => i.Quantity)</strong>
                    <span>items</span>
                </div>
            </div>

            <div class="cart-layout">
                <div class="cart-items">
                    @foreach (var item in Model.Items)
                    {
                        <div class="cart-item">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <div class="cart-item-thumb">
                                    <img src="@item.ImageUrl" alt="@item.ProductName" />
                                </div>
                            }
                            <div class="cart-item-body">
                                <div class="cart-item-info">
                                    <span class="cart-item-name">@item.ProductName</span>
                                    <span class="cart-item-category">@item.CategoryName</span>
                                </div>

                                <div class="cart-item-details">
                                    <div class="cart-item-qty">
                                        <span class="cart-item-label">Qty</span>
                                        <div class="qty-control">
                                            <form asp-controller="Cart" asp-action="UpdateQuantity" method="post">
                                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                                <input type="hidden" name="quantity" value="@(item.Quantity - 1)" />
                                                <button type="submit" class="qty-btn">-</button>
                                            </form>
                                            <span class="qty-value">@item.Quantity</span>
                                            <form asp-controller="Cart" asp-action="UpdateQuantity" method="post">
                                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                                <input type="hidden" name="quantity" value="@(item.Quantity + 1)" />
                                                <button type="submit" class="qty-btn">+</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="cart-item-remove">
                                <form asp-controller="Cart" asp-action="RemoveFromCart" method="post">
                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                    <button type="submit" title="Remove item">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>

                <div class="cart-sidebar">
                    <div class="cart-summary-card">
                        <h5>Order Summary</h5>

                        <div class="cart-totals">
                            <div class="cart-total-row">
                                <span>Subtotal</span>
                                <span>EGP @Model.Subtotal.ToString("N2")</span>
                            </div>
                            <div class="cart-total-row">
                                <span>Shipping</span>
                                <span>EGP @Model.Shipping.ToString("N2")</span>
                            </div>
                            <div class="cart-divider"></div>
                            <div class="cart-total-row cart-total-row--grand">
                                <span>Total</span>
                                <span>EGP @Model.Total.ToString("N2")</span>
                            </div>
                        </div>

                        <div class="cart-actions">
                            <a class="btn btn-primary w-100" asp-controller="Checkout" asp-action="Index">Proceed to checkout</a>
                            <a class="btn btn-outline-primary w-100" asp-controller="Products" asp-action="Index">Continue shopping</a>

                            <form asp-controller="Cart" asp-action="ClearCart" method="post" class="w-100"
                                  onsubmit="return confirm('Remove all items from your cart?');">
                                <button type="submit" class="btn btn-outline-danger w-100">
                                    <i class="bi bi-trash"></i>
                                    Clear cart
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    }
    else
    {
        <section class="section-card text-center py-5">
            <div class="mb-3" style="font-size: 2.5rem; color: var(--muted);">
                <i class="bi bi-cart-x"></i>
            </div>
            <h2 class="fw-bold mb-2">Your cart is empty</h2>
            <p class="mb-4" style="color: var(--muted);">Looks like you haven't added any products to your cart yet.</p>
            <a class="btn btn-primary" asp-controller="Products" asp-action="Index">Browse products</a>
        </section>
    }
</div>