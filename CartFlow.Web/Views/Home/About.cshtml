@{
    ViewData["Title"] = "About Us";
}

<div class="page-section">
    <section class="section-card">
        <div class="section-header text-center mb-4">
            <p class="section-label">Who We Are</p>
            <h1>About CartFlow</h1>
        </div>
        
        <div class="row justify-content-center">
            <div class="col-md-8 text-center">
                <p class="lead" style="font-size: 1.15rem; line-height: 1.8; opacity: 0.9;">
                    Welcome to <strong>CartFlow</strong>, your all-in-one shop for everything. Our mission is to provide an effortless, fast, and secure e-commerce experience tailored just for you.
                </p>
                <p class="mt-3" style="opacity: 0.75;">
                    We bring together a curated collection of high-quality products, reliable delivery networks, and support to ensure that shopping is always a breeze.
                </p>
            </div>
        </div>
    </section>

    <section class="info-grid mt-4">
        <article class="info-card text-center">
            <div class="fs-1 text-primary mb-2"><i class="bi bi-rocket-takeoff"></i></div>
            <h2>Our Mission</h2>
            <p>To deliver top-tier product quality with the speed and flexibility modern shopping demands.</p>
        </article>
        <article class="info-card text-center">
            <div class="fs-1 text-primary mb-2"><i class="bi bi-heart-fill"></i></div>
            <h2>Our Core Values</h2>
            <p>Transparency, security, and exceptional customer dedication guide everything we build.</p>
        </article>
    </section>
</div>