@{
    ViewData["Title"] = "Forgot password";
    bool submitted = ViewData["Submitted"] is true;
}

<div class="auth-page">
    <div class="auth-card">
        <div class="brand">CartFlow</div>

        @if (submitted)
        {
            <h1>Check your email</h1>
            <p class="subtitle">
                If an account exists for that email address, we've sent a link to reset your password.
                The link will expire in 1 hour.
            </p>
            <div class="auth-footer">
                <a asp-controller="Account" asp-action="SignIn">Back to sign in</a>
            </div>
        }
        else
        {
            <h1>Forgot your password?</h1>
            <p class="subtitle">Enter your email and we'll send you a link to reset it.</p>

            <form class="auth-form" asp-controller="Account" asp-action="ForgotPassword" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-semibold"></div>
                <div>
                    <label class="form-label" for="email">Email</label>
                    <input class="form-control" id="email" name="email" type="email" placeholder="name@example.com" required />
                </div>

                <button type="submit" class="btn btn-primary">Send reset link</button>
            </form>

            <div class="auth-footer">
                Remembered it? <a asp-controller="Account" asp-action="SignIn">Sign in</a>
            </div>
        }
    </div>
</div>