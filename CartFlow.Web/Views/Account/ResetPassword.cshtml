@{
    ViewData["Title"] = "Reset password";
    var email = ViewData["email"] as string;
    var token = ViewData["token"] as string;
}

<div class="auth-page">
    <div class="auth-card">
        <div class="brand">CartFlow</div>
        <h1>Choose a new password</h1>
        <p class="subtitle">Enter a new password for @email.</p>

        <form class="auth-form" asp-controller="Account" asp-action="ResetPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-semibold"></div>

            <input type="hidden" name="email" value="@email" />
            <input type="hidden" name="token" value="@token" />

            <div>
                <label class="form-label" for="newPassword">New password</label>
                <input class="form-control" id="newPassword" name="newPassword" type="password" placeholder="At least 6 characters" required minlength="6" />
            </div>

            <div>
                <label class="form-label" for="confirmPassword">Confirm new password</label>
                <input class="form-control" id="confirmPassword" name="confirmPassword" type="password" placeholder="Re-enter your new password" required minlength="6" />
            </div>

            <button type="submit" class="btn btn-primary">Reset password</button>
        </form>

        <div class="auth-footer">
            <a asp-controller="Account" asp-action="SignIn">Back to sign in</a>
        </div>
    </div>
</div>