@{
    ViewData["Title"] = "Sign in";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="brand">CartFlow</div>
        <h1>Welcome back</h1>
        <p class="subtitle">Sign in to your account to continue.</p>

        <form class="auth-form" asp-controller="Account" asp-action="SignIn" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-semibold"></div>
            <div>
                <label class="form-label" for="email">Email</label>
                <input class="form-control" id="email" name="email" type="email" placeholder="name@example.com" required />
            </div>

            <div>
                <label class="form-label" for="password">Password</label>
                <input class="form-control" id="password" name="password" type="password" placeholder="Enter your password" required />
            </div>

            <div class="form-check">
                <input class="form-check-input" id="remember" name="remember" type="checkbox" />
                <label class="form-check-label" for="remember">Remember me</label>
            </div>

            <button type="submit" class="btn btn-primary">Sign in</button>
        </form>

        <div class="auth-footer">
            Don't have an account? <a asp-controller="Account" asp-action="SignUp">Sign up</a>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
