@{
    ViewData["Title"] = "Sign in";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="brand">CartFlow</div>
        <h1>Welcome back</h1>
        <p class="subtitle">Sign in to your account to continue.</p>

        <form class="auth-form" asp-controller="Account" asp-action="SignIn" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-semibold"></div>
            <div>
                <label class="form-label" for="email">Email</label>
                <input class="form-control" id="email" name="email" type="email" placeholder="name@example.com" required />
            </div>

            
            <div>
                <div class="d-flex justify-content-between align-items-center">
                    <label class="form-label" for="password">Password</label>
                    <a asp-controller="Account" asp-action="ForgotPassword" style="font-size: 0.85rem;">Forgot password?</a>
                </div>
                <input class="form-control" id="password" name="password" type="password" placeholder="Enter your password" required />
            </div>

            <div class="form-check">
                <input class="form-check-input" id="remember" name="remember" type="checkbox" />
                <label class="form-check-label" for="remember">Remember me</label>
            </div>

            <button type="submit" class="btn btn-primary">Sign in</button>
        </form>

        <div class="auth-divider" style="display:flex; align-items:center; gap:0.75rem; margin: 1.25rem 0; color: var(--muted); font-size: 0.85rem;">
            <span style="flex:1; height:1px; background: var(--border);"></span>
            or
            <span style="flex:1; height:1px; background: var(--border);"></span>
        </div>

        <a class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2"
           asp-controller="Account" asp-action="GoogleLogin" asp-route-returnUrl="@Context.Request.Query["returnUrl"]">
            <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="" width="18" height="18" />
            Continue with Google
        </a>

        <div class="auth-footer">
            Don't have an account? <a asp-controller="Account" asp-action="SignUp">Sign up</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
