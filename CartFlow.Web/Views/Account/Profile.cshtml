@model ProfileViewModel
@{ ViewData["Title"] = "My Profile"; }

<div class="auth-page">
    <div class="auth-card">
        <div class="brand">CartFlow</div>
        <h1>My Profile</h1>
        <p class="subtitle">Update your account information.</p>

        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success">@success</div>
        }

        <form class="auth-form" method="post">
            <div>
                <label class="form-label">First Name</label>
                <input class="form-control" asp-for="FirstName" required />
                <span asp-validation-for="FirstName" class="text-danger small"></span>
            </div>
            <div>
                <label class="form-label">Last Name</label>
                <input class="form-control" asp-for="LastName" required />
                <span asp-validation-for="LastName" class="text-danger small"></span>
            </div>
            <div>
                <label class="form-label">Email</label>
                <input class="form-control" asp-for="Email" type="email" required />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div>
                <label class="form-label">Phone</label>
                <input class="form-control" asp-for="Phone" type="tel" />
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary">Save changes</button>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
