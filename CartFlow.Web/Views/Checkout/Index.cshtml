@model CartFlow.Web.Models.CheckoutViewModel

@{
    ViewData["Title"] = "Checkout";
    var stripeKey = ViewBag.StripePublishableKey as string ?? "";
}

<div class="page-section">
    <section class="section-card">
        <div class="section-header">
            <p class="section-label">Checkout</p>
            <h1>Complete your order</h1>
            <p class="section-text">Review your items and choose how to pay.</p>
        </div>

        <div class="checkout-layout">
            <form asp-controller="Checkout" asp-action="Index" method="post" class="checkout-form" id="checkout-form" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-semibold"></div>

                <input type="hidden" asp-for="PaymentMethodId" />

                <div class="checkout-fieldset">
                    <h4 class="checkout-legend"><i class="bi bi-geo-alt"></i> Shipping Address</h4>

                    <div class="field-grid">
                        <div class="field-group">
                            <label asp-for="FirstName" class="form-label">First Name</label>
                            <input asp-for="FirstName" class="form-control" placeholder="Eslam" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>

                        <div class="field-group">
                            <label asp-for="LastName" class="form-label">Last Name</label>
                            <input asp-for="LastName" class="form-control" placeholder="Mohamed" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="field-group">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="example@bsu.edu.eg" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="field-group">
                        <label asp-for="AddressLine1" class="form-label">Address</label>
                        <input asp-for="AddressLine1" class="form-control" placeholder="123 Main St, Beni Suef" />
                        <span asp-validation-for="AddressLine1" class="text-danger small"></span>
                    </div>

                    <div class="field-grid field-grid--3">
                        <div class="field-group">
                            <label asp-for="City" class="form-label">City</label>
                            <input asp-for="City" class="form-control" placeholder="Beni Suef" />
                            <span asp-validation-for="City" class="text-danger small"></span>
                        </div>

                        <div class="field-group">
                            <label asp-for="State" class="form-label">State / Region</label>
                            <input asp-for="State" class="form-control" placeholder="Beni Suef Governorate" />
                            <span asp-validation-for="State" class="text-danger small"></span>
                        </div>

                        <div class="field-group">
                            <label asp-for="PostalCode" class="form-label">Postal Code</label>
                            <input asp-for="PostalCode" class="form-control" placeholder="62511" />
                            <span asp-validation-for="PostalCode" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="checkout-fieldset">
                    <div class="payment-section">
                        <h4 class="checkout-legend"><i class="bi bi-lock-fill"></i> Payment</h4>
                        <p class="secure-notice"><i class="bi bi-shield-check"></i> All transactions are secure and encrypted.</p>

                        <div class="payment-options">
                            <label class="payment-option" id="payment-credit">
                                <input type="radio" asp-for="PaymentMethod" value="CreditCard" checked>
                                <span class="payment-option-content">
                                    <i class="bi bi-credit-card-2-front"></i>
                                    <div class="payment-option-text">
                                        <strong>Credit Card</strong>
                                        <small>Pay with VISA, Mastercard, or other cards</small>
                                    </div>
                                    <span class="card-brand-icons">
                                        <svg viewBox="0 0 48 32" width="38" height="26">
                                            <rect width="48" height="32" rx="4" fill="#1a1f71"/>
                                            <text x="24" y="20" text-anchor="middle" fill="white" font-size="10" font-weight="bold" font-family="Arial">VISA</text>
                                        </svg>
                                        <svg viewBox="0 0 48 32" width="38" height="26">
                                            <rect width="48" height="32" rx="4" fill="#eb001b"/>
                                            <circle cx="18" cy="16" r="10" fill="#f79e1b"/>
                                            <circle cx="30" cy="16" r="10" fill="#eb001b" opacity=".7"/>
                                            <text x="24" y="20" text-anchor="middle" fill="white" font-size="6" font-weight="bold" font-family="Arial">MC</text>
                                        </svg>
                                    </span>
                                </span>

                                <div class="credit-card-expand" id="credit-card-section">
                                    <div class="credit-card-body">
                                        <div class="card-field">
                                            <label class="form-label">Card Number</label>
                                            <div id="card-number-element" class="stripe-input"></div>
                                        </div>
                                        <div class="card-row">
                                            <div class="card-field">
                                                <label class="form-label">Expiry Date</label>
                                                <div id="card-expiry-element" class="stripe-input"></div>
                                            </div>
                                            <div class="card-field">
                                                <label class="form-label">CVC</label>
                                                <div id="card-cvc-element" class="stripe-input"></div>
                                            </div>
                                        </div>
                                        <div class="card-field">
                                            <label class="form-label">Cardholder Name</label>
                                            <input type="text" id="cardholder-name" class="form-control" placeholder="John Doe" value="@(Model.FirstName + " " + Model.LastName)" />
                                        </div>
                                        <div id="card-errors" class="text-danger small mt-2" role="alert"></div>
                                    </div>
                                </div>
                            </label>

                            <label class="payment-option" id="payment-cash">
                                <input type="radio" asp-for="PaymentMethod" value="Cash">
                                <span class="payment-option-content">
                                    <i class="bi bi-cash-stack"></i>
                                    <div class="payment-option-text">
                                        <strong>Cash on Delivery</strong>
                                        <small>Pay when you receive your order</small>
                                    </div>
                                </span>
                            </label>
                        </div>
                    </div>
                </div>

                <button class="btn btn-primary btn-lg fw-bold w-100 py-3" type="submit">
                    <i class="bi bi-shield-check"></i> Place Order
                </button>
            </form>

            <aside class="checkout-sidebar">
                <div class="order-summary-card">
                    <h5>Order Summary</h5>

                    @{
                        var checkoutItems = ViewBag.CartItems as List<CartFlow.Web.Models.CartItemViewModel>;
                    }

                    @if (checkoutItems != null && checkoutItems.Any())
                    {
                        <ul class="summary-items">
                            @foreach (var item in checkoutItems)
                            {
                                <li>
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <div class="summary-item-thumb">
                                            <img src="@item.ImageUrl" alt="@item.ProductName" />
                                        </div>
                                    }
                                    <div class="summary-item-info">
                                        <span class="summary-item-name">@item.ProductName</span>
                                        <span class="summary-item-qty">Qty: @item.Quantity &times; EGP @item.UnitPrice.ToString("N2")</span>
                                    </div>
                                    <span class="summary-item-price">EGP @((item.Quantity * item.UnitPrice).ToString("N2"))</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="summary-empty">No items in checkout.</p>
                    }

                    @{
                        decimal subtotal = checkoutItems?.Sum(i => i.Quantity * i.UnitPrice) ?? 0;
                        decimal shipping = 50.00m;
                        decimal total = subtotal + shipping;
                    }

                    <div class="summary-totals">
                        <div class="summary-total-row">
                            <span>Subtotal</span>
                            <span>EGP @subtotal.ToString("N2")</span>
                        </div>
                        <div class="summary-total-row">
                            <span>Shipping</span>
                            <span>EGP @shipping.ToString("N2")</span>
                        </div>
                        <div class="summary-divider"></div>
                        <div class="summary-total-row summary-total-row--grand">
                            <span>Total</span>
                            <span>EGP @total.ToString("N2")</span>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </section>
</div>

@section Scripts {
    <script src="https://js.stripe.com/v3/"></script>
    <script>
        const stripePublishableKey = '@stripeKey';
    </script>
    <script src="~/js/checkout-stripe.js"></script>
    <partial name="_ValidationScriptsPartial" />
}
