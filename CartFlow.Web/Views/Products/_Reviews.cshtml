@model List<CartFlow.Services.Models.ReviewDto>

<div class="reviews-list">
    @if (Model == null || !Model.Any())
    {
        <p class="muted">No reviews yet.</p>
    }
    else
    {
        foreach (var r in Model.OrderByDescending(x => x.CreatedAt))
        {
            <div class="review">
                <div class="review-head">
                    <strong class="review-user">@r.UserName</strong>
                    @* Inline stars: render compact star-only partial with the decimal rating *@
                    <partial name="~/Views/Shared/_StarOnly.cshtml" model="@((decimal)r.Rate)" />
                    <span class="review-date">@r.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</span>
                </div>
                <div class="review-body">@r.Comment</div>
            </div>
        }
    }
</div>
