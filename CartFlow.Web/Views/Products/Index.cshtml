@model CartFlow.Web.Models.ProductListViewModel
@{
    ViewData["Title"] = "Products";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300;400;600;700;800&display=swap" rel="stylesheet">

 <style>
    :root {
        --primary: #1a1a2e;
        --accent: #10b981;
        --accent-hover: #059669;
        --surface: #ffffff;
        --surface-alt: #f4f6f8;
        --text: #2d3436;
        --muted: #636e72;
        --border: #dfe6e9;
        --radius: 12px;
        --radius-sm: 8px;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'Bricolage Grotesque', sans-serif;
        font-size: 15px;
        line-height: 1.6;
        color: var(--text);
        background: var(--surface-alt);
    }

    .container {
        max-width: 1024px;
        margin: 0 auto;
        padding: 0 24px;
    }

    /* ── Page header ── */
    .page-header {
        background: var(--primary);
        padding: 36px 0 28px;
    }

    .page-eyebrow {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 4px;
    }

    .page-header h1 {
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        line-height: 1.15;
        margin-bottom: 2px;
    }

    .page-subtitle {
        font-size: 13px;
        color: rgba(255,255,255,.38);
        margin-bottom: 24px;
    }

    /* ── Search row ── */
    .search-row {
        display: flex;
        gap: 10px;
        align-items: center;
        margin-bottom: 20px;
    }

    .search-wrap {
        flex: 1;
        max-width: 480px;
        display: flex;
        align-items: center;
        gap: 10px;
        background: rgba(255,255,255,.07);
        border: 1px solid rgba(255,255,255,.1);
        border-radius: var(--radius-sm);
        padding: 0 14px;
        height: 42px;
        transition: border-color .2s, background .2s;
    }

        .search-wrap:focus-within {
            border-color: var(--accent);
            background: rgba(255,255,255,.11);
        }

        .search-wrap svg {
            color: rgba(255,255,255,.35);
            flex-shrink: 0;
        }

    .search-input {
        flex: 1;
        background: none;
        border: none;
        outline: none;
        color: #fff;
        font-family: inherit;
        font-size: 14px;
        padding: 0;
    }

        .search-input::placeholder {
            color: rgba(255,255,255,.3);
        }

    .header-btn {
        height: 42px;
        padding: 0 16px;
        border-radius: var(--radius-sm);
        background: rgba(255,255,255,.07);
        border: 1px solid rgba(255,255,255,.1);
        color: rgba(255,255,255,.6);
        font-family: inherit;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
        transition: all .15s;
        text-decoration: none;
    }

        .header-btn:hover {
            background: rgba(255,255,255,.13);
            color: #fff;
            border-color: rgba(255,255,255,.2);
        }

    /* ── Category chips ── */
    .chips-row {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
    }

    .chip {
        display: inline-block;
        padding: 6px 15px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.13);
        background: transparent;
        color: rgba(255,255,255,.55);
        font-family: inherit;
        font-size: 12.5px;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        transition: background .15s, border-color .15s, color .15s;
        white-space: nowrap;
    }

        .chip:hover {
            background: rgba(255,255,255,.09);
            color: rgba(255,255,255,.9);
            border-color: rgba(255,255,255,.25);
        }

        .chip.active {
            background: var(--accent);
            border-color: var(--accent);
            color: #fff;
            font-weight: 600;
        }

    /* ── Divider + stat strip ── */
    .header-divider {
        height: 1px;
        background: rgba(255,255,255,.07);
        margin: 22px 0;
    }

    .stat-strip {
        display: flex;
        gap: 0;
        padding-bottom: 4px;
    }

    .stat-item {
        flex: 1;
        padding-right: 20px;
        border-right: 1px solid rgba(255,255,255,.07);
        margin-right: 20px;
    }

        .stat-item:last-child {
            border-right: none;
            margin-right: 0;
        }

    .stat-val {
        font-size: 20px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        line-height: 1;
        margin-bottom: 2px;
    }

        .stat-val.accent {
            color: var(--accent);
        }

    .stat-label {
        font-size: 11px;
        color: rgba(255,255,255,.35);
        font-weight: 500;
    }

    /* ── Main content ── */
    .main {
        padding: 32px 0 60px;
    }

    /* ── Grid ── */
    .product-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
    }

    @@media (max-width: 900px) {
        .product-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (max-width: 640px) {
        .product-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 400px) {
        .product-grid {
            grid-template-columns: 1fr;
        }
    }

    /* ── Card ── */
    .card {
        background: var(--surface);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: transform .2s, box-shadow .2s, border-color .2s;
    }

        .card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 28px rgba(26,26,46,.11);
            border-color: #c8d6da;
        }

    /* Image area */
    .card-img {
        height: 160px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--primary) 0%, #16213e 60%, #0f3460 100%);
        flex-shrink: 0;
        position: relative;
        overflow: hidden;
    }

        .card-img::before {
            content: '';
            position: absolute;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: var(--accent);
            opacity: .12;
            top: -25px;
            right: -15px;
        }

        .card-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: absolute;
            inset: 0;
        }

    .card-initial {
        font-size: 52px;
        font-weight: 800;
        color: rgba(255,255,255,.15);
        letter-spacing: -2px;
        line-height: 1;
        position: relative;
        z-index: 1;
        user-select: none;
    }

    /* Body */
    .card-body {
        padding: 13px 13px 15px;
        display: flex;
        flex-direction: column;
        flex: 1;
        gap: 8px;
    }

    .card-name {
        font-size: 13.5px;
        font-weight: 700;
        color: var(--text);
        line-height: 1.3;
    }

    .card-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 6px;
        flex-wrap: wrap;
    }

    .badge-category {
        font-size: 10.5px;
        font-weight: 600;
        background: var(--surface-alt);
        color: var(--muted);
        border-radius: 6px;
        padding: 2px 8px;
        border: 1px solid var(--border);
    }

    .badge-stock {
        font-size: 10.5px;
        font-weight: 600;
        border-radius: 6px;
        padding: 2px 8px;
    }

        .badge-stock.in {
            background: rgba(16,185,129,.12);
            color: #065f46;
        }

        .badge-stock.low {
            background: rgba(251,191,36,.15);
            color: #92400e;
        }

        .badge-stock.out {
            background: rgba(239,68,68,.10);
            color: #991b1b;
        }

    .card-price {
        font-size: 16px;
        font-weight: 800;
        color: var(--accent);
        letter-spacing: -0.3px;
        margin-top: auto;
    }

        .card-price span {
            font-size: 10.5px;
            font-weight: 600;
            opacity: .75;
            margin-right: 2px;
        }

    .card-actions {
        display: flex;
        gap: 6px;
        margin-top: 2px;
    }

    .btn-cart {
        flex: 1;
        padding: 8px 0;
        background: var(--accent);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        font-family: inherit;
        font-size: 12.5px;
        font-weight: 600;
        cursor: pointer;
        transition: background .15s;
        text-align: center;
    }

        .btn-cart:hover:not(:disabled) {
            background: var(--accent-hover);
        }

        .btn-cart:disabled {
            background: var(--border);
            color: var(--muted);
            cursor: not-allowed;
        }

    .btn-details {
        height: 33px;
        width: 33px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--surface-alt);
        color: var(--muted);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        text-decoration: none;
        font-size: 16px;
        transition: border-color .15s, color .15s, background .15s;
    }

        .btn-details:hover {
            border-color: var(--accent);
            color: var(--accent);
            background: rgba(16,185,129,.05);
        }

    /* ── Empty state ── */
    .empty-state {
        text-align: center;
        padding: 80px 20px;
    }

        .empty-state svg {
            color: var(--border);
            margin-bottom: 20px;
        }

        .empty-state h3 {
            font-size: 18px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 6px;
        }

        .empty-state p {
            color: var(--muted);
            font-size: 14px;
        }
</style>

<!-- Page header -->
<div class="page-header">
    <div class="container">
        <div class="page-eyebrow">CartFlow Store</div>
        <h1>Products</h1>
        <p class="page-subtitle">Browse our full collection</p>

        <form method="get" action="">
            <!-- Search + action buttons -->
            <div class="search-row">
                <div class="search-wrap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8" />
                        <path d="m21 21-4.35-4.35" />
                    </svg>
                    <input class="search-input" type="text" name="searchTerm"
                           value="@Model.SearchTerm"
                           placeholder="Search products…"
                           autocomplete="off" />
                </div>

                <button type="submit" class="header-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M3 4a1 1 0 0 1 1-1h16a1 1 0 0 1 .78 1.63L14 12.17V19a1 1 0 0 1-1.45.89l-4-2A1 1 0 0 1 8 17v-4.83L3.22 5.63A1 1 0 0 1 3 4z" />
                    </svg>
                    Filter
                </button>
            </div>

            <!-- Category chips -->
            <div class="chips-row">
                <a href="?searchTerm=@Model.SearchTerm"
                   class="chip @(Model.SelectedCategoryId == null ? "active" : "")">All</a>

                @foreach (var cat in Model.Categories)
                {
                    <a href="?searchTerm=@Model.SearchTerm&categoryId=@cat.Id"
                       class="chip @(Model.SelectedCategoryId == cat.Id ? "active" : "")">
                        @cat.Name
                    </a>
                }
            </div>
        </form>

        <!-- Divider + stat strip -->
        <div class="header-divider"></div>

        <div class="stat-strip">
            <div class="stat-item">
                <div class="stat-val">@Model.Products.Count</div>
                <div class="stat-label">Products</div>
            </div>
            <div class="stat-item">
                <div class="stat-val">@Model.Categories.Count</div>
                <div class="stat-label">Categories</div>
            </div>
            <div class="stat-item">
                <div class="stat-val">@Model.Products.Count(p => p.StockQuantity > 0)</div>
                <div class="stat-label">In stock</div>
            </div>
            <div class="stat-item">
                <div class="stat-val accent">EGP</div>
                <div class="stat-label">Local pricing</div>
            </div>
        </div>
    </div>
</div>

<!-- Product grid -->
<div class="main">
    <div class="container">

        @if (!Model.Products.Any())
        {
            <div class="empty-state">
                <svg xmlns="http://www.w3.org/2000/svg" width="72" height="72" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M21 21l-4.35-4.35M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z" />
                </svg>
                <h3>No products found</h3>
                <p>Try a different search term or browse all categories.</p>
            </div>
        }
        else
        {
            <div class="product-grid">
                @foreach (var p in Model.Products)
                {
                    <div class="card">
                        <div class="card-img">
                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                            {
                                <img src="@p.ImageUrl" alt="@p.Name" />
                            }
                            else
                            {
                                <span class="card-initial">@p.Initial</span>
                            }
                        </div>

                        <div class="card-body">
                            <div class="card-name">@p.Name</div>

                            <div class="card-meta">
                                <span class="badge-category">@p.CategoryName</span>
                                <span class="badge-stock @(p.StockQuantity > 10 ? "in" : p.StockQuantity > 0 ? "low" : "out")">
                                    @(p.StockQuantity > 10 ? "In Stock" : p.StockQuantity > 0 ? "Low Stock" : "Out of Stock")
                                </span>
                            </div>

                            <div class="card-price">
                                <span>EGP</span>@p.UnitPrice.ToString("N2")
                            </div>

                            <div class="card-actions">
                                <button class="btn-cart" @(p.StockQuantity == 0 ? "disabled" : "")>
                                    @(p.StockQuantity == 0 ? "Out of stock" : "Add to cart")
                                </button>
                                <a class="btn-details" asp-action="Details" asp-route-id="@p.Id"
                                   title="View details">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none"
                                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

    </div>
</div>
        