@model CartFlow.Web.Models.ProductListViewModel
@{
    ViewData["Title"] = "Products";
}

<div class="page-section">
    <section class="section-card">
        <div class="section-header">
            <p class="section-label">CartFlow Store</p>
            <h1>Products</h1>
        </div>

        <form method="get" action="" style="margin-top: 0.75rem;">
            <div class="search-bar">
                <input class="form-control" type="text" name="searchTerm" id="searchInput"
                       value="@Model.SearchTerm" placeholder="Search products…" autocomplete="off" />
                <button type="submit" class="btn btn-primary btn-sm" id="searchSubmit">Search</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="searchClear"
                        style="display:@(string.IsNullOrEmpty(Model.SearchTerm) ? "none" : "inline-block")">Clear</button>
            </div>

            <div class="filter-chips">
                <a href="?searchTerm=@Model.SearchTerm"
                   class="filter-chip @(Model.SelectedCategoryId == null ? "active" : "")">All</a>
                @foreach (var cat in Model.Categories)
                {
                    <a href="?searchTerm=@Model.SearchTerm&categoryId=@cat.Id"
                       class="filter-chip @(Model.SelectedCategoryId == cat.Id ? "active" : "")">
                        @cat.Name
                    </a>
                }
            </div>
        </form>
    </section>

    <div id="productsContainer">
        <partial name="_ProductGrid" model="@Model" />
    </div>
</div>

<script>
    // Live search: 300ms debounce, Fetch API + AbortController. Preserves category filter.
    const searchInput = document.getElementById('searchInput');
    const searchClear = document.getElementById('searchClear');
    const searchSubmit = document.getElementById('searchSubmit');
    const productsContainer = document.getElementById('productsContainer');
    let currentCategoryId = '@(Model.SelectedCategoryId?.ToString() ?? "")';
    let currentAbortController = null;

    function debounce(fn, delay) {
        let t;
        return (...args) => {
            clearTimeout(t);
            t = setTimeout(() => fn(...args), delay);
        };
    }

    function toggleClearBtn() {
        if (!searchClear || !searchInput) return;
        searchClear.style.display = searchInput.value.length > 0 ? 'inline-block' : 'none';
    }

    async function performSearch(term, categoryId) {
        if (!productsContainer) return;
        const params = new URLSearchParams();
        if (term) params.set('searchTerm', term);
        if (categoryId) params.set('categoryId', categoryId);
        const url = window.location.pathname + (params.toString() ? '?' + params.toString() : '');

        if (currentAbortController) {
            try { currentAbortController.abort(); } catch (e) { }
        }
        const controller = new AbortController();
        currentAbortController = controller;

        if (searchSubmit) {
            searchSubmit.disabled = true;
            searchSubmit.textContent = 'Searching…';
        }

        try {
            const res = await fetch(url, {
                headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'text/html' },
                signal: controller.signal
            });

            if (!res.ok) throw new Error('Network response was not ok');
            const html = await res.text();

            if (controller !== currentAbortController) return;

            productsContainer.innerHTML = html;
        }
        catch (e) {
            if (e && (e.name === 'AbortError' || e.code === 'ERR_ABORTED')) return;
            console.error('Live search error', e);
        }
        finally {
            if (searchSubmit && controller === currentAbortController) {
                searchSubmit.disabled = false;
                searchSubmit.textContent = 'Search';
                currentAbortController = null;
            }
        }
    }

    const debouncedSearch = debounce(() => performSearch(searchInput.value.trim(), currentCategoryId || undefined), 300);

    if (searchInput) searchInput.addEventListener('input', () => { toggleClearBtn(); debouncedSearch(); });
    if (searchClear) searchClear.addEventListener('click', () => { if (searchInput) searchInput.value = ''; toggleClearBtn(); debouncedSearch(); });

    document.querySelectorAll('.filter-chip').forEach(a => {
        a.addEventListener('click', e => {
            e.preventDefault();
            const href = new URL(a.href, window.location.origin);
            const cat = href.searchParams.get('categoryId');
            currentCategoryId = cat || '';

            document.querySelectorAll('.filter-chip').forEach(x => x.classList.remove('active'));
            a.classList.add('active');

            const term = href.searchParams.get('searchTerm') || '';
            if (searchInput) searchInput.value = term;
            toggleClearBtn();

            debouncedSearch();
        });
    });

    const form = searchInput ? searchInput.closest('form') : null;
    if (form) {
        form.addEventListener('submit', (e) => {
            e.preventDefault();
            performSearch(searchInput.value.trim(), currentCategoryId || undefined);
        });
    }

    toggleClearBtn();
</script>
