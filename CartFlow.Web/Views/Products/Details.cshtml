@model CartFlow.Web.Models.ProductViewModel
@{
    ViewData["Title"] = Model.Name;
}

<style>
    :root {
        --primary: #1a1a2e;
        --accent: #10b981;
        --accent-hover: #059669;
        --surface: #ffffff;
        --surface-alt: #f4f6f8;
        --text: #2d3436;
        --muted: #636e72;
        --border: #dfe6e9;
        --radius: 12px;
        --radius-sm: 8px;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'Bricolage Grotesque', sans-serif;
        font-size: 15px;
        line-height: 1.6;
        color: var(--text);
        background: var(--surface-alt);
    }

    .container {
        max-width: 1024px;
        margin: 0 auto;
        padding: 0 20px;
    }

    /* ── Breadcrumb strip ── */
    .breadcrumb-bar {
        background: var(--primary);
        padding: 14px 0;
    }

    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: rgba(255,255,255,.5);
    }

        .breadcrumb a {
            color: rgba(255,255,255,.7);
            text-decoration: none;
            transition: color .15s;
        }

            .breadcrumb a:hover {
                color: var(--accent);
            }

        .breadcrumb svg {
            flex-shrink: 0;
        }

        .breadcrumb span {
            color: rgba(255,255,255,.9);
        }

    /* ── Main layout ── */
    .main {
        padding: 40px 0 72px;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        align-items: start;
    }

    @@media (max-width: 680px) {
        .detail-grid {
            grid-template-columns: 1fr;
            gap: 28px;
        }
    }

    /* ── Left: image ── */
    .img-panel {
        background: linear-gradient(135deg, var(--primary) 0%, #16213e 60%, #0f3460 100%);
        border-radius: var(--radius);
        width: 100%;
        aspect-ratio: 1 / 1;
        max-width: 400px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

        .img-panel::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 70% 25%, rgba(16,185,129,.22) 0%, transparent 65%);
        }

        .img-panel img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: absolute;
            inset: 0;
            border-radius: var(--radius);
        }

    .img-initial {
        font-size: 120px;
        font-weight: 800;
        color: rgba(255,255,255,.15);
        line-height: 1;
        letter-spacing: -4px;
        position: relative;
        z-index: 1;
        user-select: none;
    }

    /* ── Right: info panel ── */
    .info-panel {
        background: var(--surface);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        padding: 32px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

        .info-panel h2 {
            font-size: 26px;
            font-weight: 800;
            color: var(--text);
            line-height: 1.2;
            letter-spacing: -0.4px;
        }

    .category-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--muted);
        text-decoration: none;
        background: var(--surface-alt);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 4px 12px;
        transition: border-color .15s, color .15s;
        width: fit-content;
    }

        .category-link:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

    .price-display {
        font-size: 30px;
        font-weight: 800;
        color: var(--accent);
        letter-spacing: -0.5px;
        line-height: 1;
    }

        .price-display .currency {
            font-size: 16px;
            font-weight: 700;
            margin-right: 4px;
            vertical-align: baseline;
        }

    .divider {
        height: 1px;
        background: var(--border);
    }

    .description {
        font-size: 14px;
        color: var(--muted);
        line-height: 1.7;
    }

    .stock-row {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
    }

    .stock-label {
        color: var(--muted);
        font-weight: 500;
    }

    .stock-value {
        font-weight: 700;
        color: var(--text);
    }

    /* Quantity selector */
    .qty-block {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .qty-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--muted);
    }

    .qty-input {
        width: 90px;
        padding: 9px 12px;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        font-family: inherit;
        font-size: 15px;
        font-weight: 600;
        color: var(--text);
        outline: none;
        transition: border-color .15s;
        -moz-appearance: textfield;
    }

        .qty-input::-webkit-inner-spin-button,
        .qty-input::-webkit-outer-spin-button {
            opacity: 1;
        }

        .qty-input:focus {
            border-color: var(--accent);
        }

    /* Buttons */
    .btn-add-cart {
        width: 100%;
        padding: 13px;
        background: var(--accent);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        font-family: inherit;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: background .15s, transform .1s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .btn-add-cart:hover {
            background: var(--accent-hover);
        }

        .btn-add-cart:active {
            transform: scale(.99);
        }

        .btn-add-cart:disabled {
            background: var(--border);
            color: var(--muted);
            cursor: not-allowed;
        }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--muted);
        text-decoration: none;
        transition: color .15s;
    }

        .back-link:hover {
            color: var(--accent);
        }
</style>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&display=swap" rel="stylesheet">

<!-- Breadcrumb -->
<div class="breadcrumb-bar">
    <div class="container">
        <nav class="breadcrumb">
            <a asp-action="Index">Products</a>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
            <span>@Model.Name</span>
        </nav>
    </div>
</div>

<!-- Detail layout -->
<div class="main">
    <div class="container">
        <div class="detail-grid">

            <!-- Left: image -->
            <div class="img-panel">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name" />
                }
                else
                {
                    <span class="img-initial">@Model.Initial</span>
                }
            </div>

            <!-- Right: info -->
            <div class="info-panel">

                <h2>@Model.Name</h2>

                <a asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="category-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M7 7h.01M3 3h8l9 9a2 2 0 0 1 0 2.83l-5.17 5.17a2 2 0 0 1-2.83 0L3 11V3z" />
                    </svg>
                    @Model.CategoryName
                </a>

                <div class="price-display">
                    <span class="currency">EGP</span>@Model.UnitPrice.ToString("N2")
                </div>

                <div class="divider"></div>

                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <p class="description">@Model.Description</p>
                }

                <div class="stock-row">
                    <span class="stock-label">Stock:</span>
                    <span class="stock-value">@Model.StockQuantity units available</span>
                </div>

                <!-- Quantity -->
                <div class="qty-block">
                    <label class="qty-label" for="qty">Quantity</label>
                    <input class="qty-input" type="number" id="qty" name="qty"
                           min="1" max="10" value="1"
                    @(Model.StockQuantity == 0 ? "disabled" : "") />
                </div>

                <!-- Add to Cart -->
                <button class="btn-add-cart" @(Model.StockQuantity == 0 ? "disabled" : "")>
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.35 2.7A1 1 0 0 0 6.54 17H17M9 21a1 1 0 1 0 2 0 1 1 0 0 0-2 0zm8 0a1 1 0 1 0 2 0 1 1 0 0 0-2 0z" />
                    </svg>
                    @(Model.StockQuantity == 0 ? "Out of Stock" : "Add to Cart")
                </button>

                <!-- Back link -->
                <a asp-action="Index" class="back-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                    </svg>
                    Back to products
                </a>

            </div>
        </div>
    </div>
</div>
