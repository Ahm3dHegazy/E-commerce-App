@model CartFlow.Web.Models.ProductViewModel
@{
    ViewData["Title"] = Model.Name;
}

<link rel="stylesheet" href="~/css/products.css" asp-append-version="true" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&display=swap" rel="stylesheet">

<style>
    /* Fix: .img-panel was capped at max-width:400px in products.css,
                       causing empty space in its grid column before the info panel starts */
    .img-panel {
        max-width: none;
        width: 100%;
        aspect-ratio: auto;
        min-height: 480px;
    }

        .img-panel img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: absolute;
            inset: 0;
        }

    /* Buy Now button — secondary style, sits under Add to Cart */
    .btn-buy-now {
        width: 100%;
        padding: 13px;
        background: transparent;
        color: var(--accent);
        border: 1.5px solid var(--accent);
        border-radius: var(--radius-sm);
        font-family: inherit;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: background .15s, color .15s, transform .1s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-decoration: none;
        margin-top: 10px;
    }

        .btn-buy-now:hover {
            background: var(--accent);
            color: #fff;
        }

        .btn-buy-now:active {
            transform: scale(.99);
        }

        .btn-buy-now:disabled {
            background: transparent;
            border-color: var(--border);
            color: var(--muted);
            cursor: not-allowed;
        }
</style>

<div class="breadcrumb-bar">
    <nav class="breadcrumb">
        <a asp-action="Index">Products</a>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none"
             viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <span>@Model.Name</span>
    </nav>
</div>

<div class="main">
    <div class="detail-grid detail-grid--reviews">

        <div>
            <div class="img-panel">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img id="mainImage" src="@Model.ImageUrl" alt="@Model.Name" />
                }
                else
                {
                    <span class="img-initial">@Model.Initial</span>
                }
            </div>

            @if (Model.ImageUrls != null && Model.ImageUrls.Any())
            {
                <div class="thumbnails" role="list">
                    @foreach (var img in Model.ImageUrls)
                    {
                        var active = img == Model.ImageUrl ? "active" : string.Empty;
                        <button type="button" class="thumb @active" data-src="@img" aria-label="Thumbnail">
                            <img src="@img" alt="@Model.Name" />
                        </button>
                    }
                </div>
            }
        </div>

        <div class="info-panel">

            <a asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="category-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M7 7h.01M3 3h8l9 9a2 2 0 0 1 0 2.83l-5.17 5.17a2 2 0 0 1-2.83 0L3 11V3z" />
                </svg>
                @Model.CategoryName
            </a>

            <h2>@Model.Name</h2>

            <div class="rating-summary" style="display:flex;align-items:center;gap:8px;">
                @{
                    var avg = Model.AverageRating;
                    var count = Model.ReviewCount;
                }
                @Html.Partial("~/Views/Shared/_StarOnly.cshtml", avg)
                <span class="avg-rating-text" style="font-weight:600;">@avg.ToString("0.0")</span>
                <span class="rating-count" style="opacity:.8;">(@count reviews)</span>
            </div>

            <div class="divider"></div>

            <div class="price-display">
                <span class="currency">EGP</span>@Model.UnitPrice.ToString("N2")
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="description">@Model.Description</p>
            }

            <div class="divider"></div>

            <div class="stock-row">
                <span class="stock-dot" aria-hidden="true"></span>
                <span class="stock-value">@(Model.StockQuantity > 0 ? "In Stock" : "Out of Stock")</span>
                <span class="stock-count">(@Model.StockQuantity units available)</span>
            </div>

            <div class="qty-block">
                <label class="qty-label" for="qtyInput">Quantity</label>
                <div class="qty-control">
                    <button type="button" class="btn-qty" data-action="decrement">-</button>
                    <input class="qty-input" type="number" id="qtyInput" name="quantity" min="1" max="@Model.StockQuantity" value="1" form="addToCartForm" />
                    <button type="button" class="btn-qty" data-action="increment">+</button>
                </div>
            </div>

            <form id="addToCartForm" asp-controller="Cart" asp-action="AddToCart" method="post" class="d-flex flex-column gap-3 add-to-cart-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="productId" value="@Model.Id" />

                <button type="submit" class="btn-add-cart" @(Model.StockQuantity == 0 ? "disabled" : "")>
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.35 2.7A1 1 0 0 0 6.54 17H17M9 21a1 1 0 1 0 2 0 1 1 0 0 0-2 0zm8 0a1 1 0 1 0 2 0 1 1 0 0 0-2 0z" />
                    </svg>
                    @(Model.StockQuantity == 0 ? "Out of Stock" : "Add to Cart")
                </button>
            </form>

            <form asp-controller="Checkout" asp-action="Index" method="get">
                <input type="hidden" name="productId" value="@Model.Id" />
                <input type="hidden" id="buyNowQty" name="quantity" value="1" />

                <button type="submit" class="btn-buy-now" @(Model.StockQuantity == 0 ? "disabled" : "")>
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M13 7l5 5-5 5M6 12h12" />
                    </svg>
                    @(Model.StockQuantity == 0 ? "Out of Stock" : "Buy Now")
                </button>
            </form>

            <a asp-action="Index" class="back-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                </svg>
                Back to products
            </a>

        </div>
    </div>

    @if (Model.RelatedProducts != null && Model.RelatedProducts.Any())
    {
        <div class="related-products-section" style="margin-top: 2.5rem; margin-bottom: 2.5rem;">
            <h4 class="mb-3" style="font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700;">Related Products</h4>
            <div class="product-grid">
                @foreach (var rp in Model.RelatedProducts)
                {
                    <div class="product-card">
                        <div class="product-image">
                            <a href="@Url.Action("Details", "Products", new { id = rp.Id })" style="display:flex;width:100%;height:100%;align-items:center;justify-content:center;text-decoration:none;overflow:hidden;">
                                @if (!string.IsNullOrEmpty(rp.ImageUrl))
                                {
                                    <img src="@rp.ImageUrl" alt="@rp.Name" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" />
                                }
                                else
                                {
                                    <span style="font-size:3rem;font-weight:800;color:rgba(255,255,255,.15);user-select:none;">@rp.Initial</span>
                                }
                            </a>
                        </div>

                        <div class="product-body">
                            <h3>@rp.Name</h3>

                            <div>
                                <span class="category-badge">@rp.CategoryName</span>
                            </div>

                            <div class="product-meta">
                                <span class="price">
                                    <span style="font-size:.7rem;font-weight:600;opacity:.75;">EGP</span> @rp.UnitPrice.ToString("N2")
                                </span>
                                <span class="stock-badge @(rp.StockQuantity > 10 ? "stock-in" : rp.StockQuantity > 0 ? "stock-low" : "stock-out")">
                                    @(rp.StockQuantity > 10 ? "In Stock" : rp.StockQuantity > 0 ? "Low Stock" : "Out of Stock")
                                </span>
                            </div>

                            <div class="action-row">
                                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="w-100 add-to-cart-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@rp.Id" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <button type="submit" class="btn btn-primary btn-sm w-100" @(rp.StockQuantity == 0 ? "disabled" : "")>
                                        @(rp.StockQuantity == 0 ? "Out of stock" : "Add to cart")
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

<div class="reviews-section">
        <div class="reviews-inner">
            <h4 class="reviews-heading">Reviews <span class="reviews-count">(@Model.ReviewCount)</span></h4>

            <div class="reviews-list">
                @if (Model.Reviews != null && Model.Reviews.Any())
                {
                    @foreach (var r in Model.Reviews)
                    {
                        <div class="review-card">
                            <div class="review-header">
                                <div class="review-avatar">@(string.IsNullOrEmpty(r.UserName) ? "U" : r.UserName[0])</div>
                                <div class="review-meta">
                                    <span class="review-name">@r.UserName</span>
                                    <div class="review-stars">
                                        @Html.Partial("~/Views/Shared/_StarOnly.cshtml", (decimal)r.Rate)
                                    </div>
                                </div>
                                <span class="review-date">@DateTime.Today.ToString("yyyy-MM-dd")</span>
                            </div>
                            <p class="review-text">@r.Comment</p>
                        </div>
                    }
                }
                else
                {
                    <p style="padding: 0.25rem 0; margin-bottom: 0; color: var(--muted);">No reviews yet for this product. Be the first to review!</p>
                }
            </div>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="review-form-wrapper">
                    <h5 class="review-form-heading">Write a Review</h5>
                    <form asp-action="AddReview" method="post" class="review-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@Model.Id" />

                        <div class="form-group">
                            <label for="rating">Rating</label>
                            <select name="rating" id="rating" class="form-control" required>
                                <option value="">Select rating</option>
                                <option value="5">★★★★★ (5)</option>
                                <option value="4">★★★★☆ (4)</option>
                                <option value="3">★★★☆☆ (3)</option>
                                <option value="2">★★☆☆☆ (2)</option>
                                <option value="1">★☆☆☆☆ (1)</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="comment">Comment</label>
                            <textarea name="comment" id="comment" class="form-control" rows="4" required
                                      placeholder="Share your experience with this product..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary">Submit Review</button>
                    </form>
                </div>
            }
            else
            {
                <p class="text-muted" style="margin-top:1rem;">
                    <a asp-controller="Account" asp-action="SignIn">Sign in</a> to write a review.
                </p>
            }
        </div>
    </div>
</div>

<script>
    (function(){
        // Thumbnail click swaps main image
        document.addEventListener('click', function(e){
            var btn = e.target.closest('.thumb');
            if(!btn) return;
            var src = btn.getAttribute('data-src');
            if(src){
                var main = document.getElementById('mainImage');
                if(main) main.src = src;
                document.querySelectorAll('.thumbnails .thumb').forEach(t=>t.classList.remove('active'));
                btn.classList.add('active');
            }
        });

        // Quantity buttons — keep qtyInput and buyNowQty in sync
        document.addEventListener('click', function(e){
            var action = e.target.getAttribute('data-action') || e.target.closest('[data-action]')?.getAttribute('data-action');
            if(!action) return;
            var input = document.getElementById('qtyInput');
            if(!input) return;
            var val = parseInt(input.value || '1');
            if(action === 'increment') val = Math.min(val + 1, 999);
            if(action === 'decrement') val = Math.max(val - 1, 1);
            input.value = val;

            var buyNowQty = document.getElementById('buyNowQty');
            if(buyNowQty) buyNowQty.value = val;
        });

        // Keep buyNowQty synced if user types directly into qtyInput
        document.addEventListener('input', function(e){
            if(e.target.id === 'qtyInput'){
                var buyNowQty = document.getElementById('buyNowQty');
                if(buyNowQty) buyNowQty.value = e.target.value || '1';
            }
        });
    })();
</script>