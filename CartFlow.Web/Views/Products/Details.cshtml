@model Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="page-section">
    <section class="section-card">
        <div class="section-header section-header--row">
            <div>
                <p class="section-label">Product</p>
                <h1>@Model.Name</h1>
                <p class="section-text">@Model.Description</p>
            </div>
            <div class="summary-chip summary-chip--price">
                <strong>EGP @Model.UnitPrice.ToString("N2")</strong>
                <span>per unit</span>
            </div>
        </div>

        <div class="details-list">
            <div>
                <span>Category</span>
                <strong>@Model.Category?.Name</strong>
            </div>
            <div>
                <span>Stock</span>
                <strong>@Model.StockQuantity</strong>
            </div>
            <div>
                <span>Product ID</span>
                <strong>@Model.Id</strong>
            </div>
        </div>

        <div class="mt-3">
            <a class="btn btn-outline-secondary" asp-action="Index">Back to products</a>
        </div>
    </section>
</div>
