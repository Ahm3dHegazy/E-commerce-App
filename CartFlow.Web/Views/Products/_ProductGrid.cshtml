@model CartFlow.Web.Models.ProductListViewModel

@if (!Model.Products.Any())
{
    <div class="empty-state">
        <div class="icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M21 21l-4.35-4.35M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z" />
            </svg>
        </div>
        <h3>No products found</h3>
        <p>Try a different search term or browse all categories.</p>
    </div>
}
else
{
    <div class="product-grid">
        @foreach (var p in Model.Products)
        {
            <div class="product-card">
                <div class="product-image">
                    <a href="@Url.Action("Details", "Products", new { id = p.Id })" style="display:flex;width:100%;height:100%;align-items:center;justify-content:center;text-decoration:none;overflow:hidden;">
                        @if (!string.IsNullOrEmpty(p.ImageUrl))
                        {
                            <img src="@p.ImageUrl" alt="@p.Name" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" />
                        }
                        else
                        {
                            <span style="font-size:3rem;font-weight:800;color:rgba(255,255,255,.15);user-select:none;">@p.Initial</span>
                        }
                    </a>
                </div>

                <div class="product-body">
                    <h3>@p.Name</h3>

                    <div>
                        <span class="category-badge">@p.CategoryName</span>
                    </div>

                    @* Star rating placed below name and above price. Uses shared partial. *@
                    <div class="mt-2" style="display:inline-flex;align-items:center;gap:8px;">
                        @{ var avg = p.Reviews?.Any() == true ? Math.Round(p.Reviews.Average(r => r.Rate), 1) : 0m; var count = p.Reviews?.Count() ?? 0; }
                        @Html.Partial("~/Views/Shared/_StarOnly.cshtml", avg)
                        <span class="avg-rating-text" style="margin-left:6px;font-weight:600;">@avg.ToString("0.0")</span>
                        <span class="rating-count" style="margin-left:6px;opacity:.8;">(@count reviews)</span>
                    </div>

                    <div class="product-meta">
                        <span class="price">
                            <span style="font-size:.7rem;font-weight:600;opacity:.75;">EGP</span> @p.UnitPrice.ToString("N2")
                        </span>
                        <span class="stock-badge @(p.StockQuantity > 10 ? "stock-in" : p.StockQuantity > 0 ? "stock-low" : "stock-out")">
                            @(p.StockQuantity > 10 ? "In Stock" : p.StockQuantity > 0 ? "Low Stock" : "Out of Stock")
                        </span>
                    </div>

                    <div class="action-row">

                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="w-100">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@p.Id" />
                            <input type="hidden" name="quantity" value="1" />
                            <button type="submit" class="btn btn-primary btn-sm w-100" @(p.StockQuantity == 0 ? "disabled" : "")>
                                @(p.StockQuantity == 0 ? "Out of stock" : "Add to cart")
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}