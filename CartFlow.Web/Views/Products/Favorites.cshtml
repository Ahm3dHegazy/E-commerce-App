@model List<CartFlow.Web.Models.ProductViewModel>
@{
    ViewData["Title"] = "My Favorites";
}

<div class="container my-5">
    <div class="d-flex align-items-center gap-3 mb-4">
        <i class="bi bi-heart-fill text-danger fs-2"></i>
        <h2 class="mb-0" style="font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700;">My Favorite Products</h2>
    </div>
    <hr />

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var product in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 product-card" style="position:relative; transition: transform 0.2s; border-radius: 12px; overflow: hidden;">
                        
                        <div class="product-image" style="height: 240px; background-color: #f8f9fa; display: flex; align-items: center; justify-content: center; position: relative;">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="width: 100%; height: 100%; object-fit: cover;">
                            }
                            else
                            {
                                <span style="font-size: 2.5rem; font-weight: 800; color: #ddd;">@product.Initial</span>
                            }
                        </div>

                        <div class="card-body d-flex flex-column justify-content-between p-3">
                            <div>
                                <span class="badge bg-light text-secondary mb-2" style="font-size: 0.75rem;">@product.CategoryName</span>
                                <h5 class="card-title text-dark text-truncate" style="font-size: 1.05rem; font-weight: 600; margin-bottom: 0.5rem;">@product.Name</h5>
                            </div>
                            
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="text-success fw-bold" style="font-size: 1.1rem;">
                                    <span style="font-size: 0.75rem; font-weight: 600; opacity: 0.8;">EGP</span> @product.UnitPrice.ToString("N2")
                                </span>
                                <a href="/Products/Details/@product.Id" class="btn btn-outline-primary btn-sm rounded-pill px-3">View Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="mb-3 text-muted">
                <i class="bi bi-heart" style="font-size: 4rem; opacity: 0.3;"></i>
            </div>
            <h3 class="text-secondary">Your favorites list is empty</h3>
            <p class="text-muted">Explore our products and tap the heart icon to save your top picks here.</p>
            <a href="/Products" class="btn btn-primary rounded-pill mt-3 px-4">Browse Products</a>
        </div>
    }
</div>