@model IEnumerable<CartFlow.Data.Entities.Category>

@{
    ViewData["Title"] = "Categories";
}

<div class="page-section">
    <section class="section-card">
        <div class="section-header">
            <p class="section-label">Catalog</p>
            <h1>Categories</h1>
            <p class="section-text">Browse categories, explore subcategories and view products as cards.</p>
        </div>

        @foreach (var category in Model) {
            <div class="category-block mt-4">
                <h2 class="category-title">@category.Name</h2>
                <p class="category-desc">@category.Descripion</p>

                <div class="subcategories-grid mt-3">
                    @foreach (var sub in category.Subcategories) {
                        <div class="subcategory-card">
                            <h3>@sub.Name</h3>
                            <p class="text-muted">@sub.Descripion</p>

                            <div class="products-grid mt-2">
                                @foreach (var product in sub.Products) {
                                    <div class="product-card">
                                        <div class="product-image">
                                            <!-- if there's a primary image show it otherwise placeholder -->
                                            @if (product.PrimaryImage != null) {
                                                <img src="@product.PrimaryImage.Image" alt="@product.Name" />
                                            } else {
                                                <div class="image-placeholder">No image</div>
                                            }
                                        </div>
                                        <div class="product-body">
                                            <div class="fw-semibold">@product.Name</div>
                                            <div class="text-muted small text-truncate">@product.Description</div>
                                            <div class="product-meta mt-2">
                                                <strong>EGP @product.UnitPrice.ToString("N2")</strong>
                                                <span class="ms-2 text-muted">Stock: @product.StockQuantity</span>
                                            </div>
                                            <div class="mt-2">
                                                <a class="btn btn-sm btn-outline-primary" asp-controller="Products" asp-action="Details" asp-route-id="@product.Id">Details</a>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </section>
</div>
